# Example Environment Configuration for Exgentic A2A Runner
# Copy this file to .env and customize for your environment

# ============================================================
# AUTOMATICALLY SETUP CONFIGURATION
# ============================================================

# NOTE: When using evaluate_benchmark.sh, EXGENTIC_MCP_SERVER_URL and A2A_BASE_URL
# are automatically set to localhost:7770 and localhost:7701 respectively.
# You only need to set them manually if running the runner directly without the script.

# Exgentic MCP Server URL (set automatically by evaluate_benchmark.sh)
# EXGENTIC_MCP_SERVER_URL=http://localhost:7770/mcp

# A2A endpoint base URL (set automatically by evaluate_benchmark.sh)
# A2A_BASE_URL=http://localhost:7701


# ============================================================
# EXGENTIC CONFIGURATION (Optional)
# ============================================================

# MCP operation timeout in seconds (default: 60)
EXGENTIC_MCP_TIMEOUT_SECONDS=60

# Maximum number of tasks/sessions to process (useful for testing)
MAX_TASKS=1

# Maximum number of parallel sessions to run concurrently (default: 1)
# Set to 1 for sequential processing, higher values for parallel execution
# Example: MAX_PARALLEL_SESSIONS=5 will run up to 5 sessions simultaneously
MAX_PARALLEL_SESSIONS=1

# Stop processing on first failure (default: false)
ABORT_ON_FAILURE=false

# ============================================================
# A2A CONFIGURATION (Optional)
# ============================================================

# Request timeout in seconds (default: 300)
A2A_TIMEOUT_SECONDS=300

# Bearer token for authentication (if required by your endpoint)
# A2A_AUTH_TOKEN=your-secret-token-here

# Verify TLS certificates (default: true)
A2A_VERIFY_TLS=true

# Custom endpoint path (default: /v1/chat)
# For A2A JSON-RPC protocol, use root path
A2A_ENDPOINT_PATH=/

# ============================================================
# OPENTELEMETRY CONFIGURATION (Optional)
# ============================================================

# Service name for telemetry (default: exgentic-a2a-runner)
OTEL_SERVICE_NAME=exgentic-a2a-runner

# OTLP exporter endpoint (if not set, telemetry won't be exported and no console output)
# For local Jaeger: uncomment the line below after starting Jaeger with Docker
# See README.md "OpenTelemetry and Observability" section for setup instructions
#OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# OTLP protocol (default: grpc)
# Options: grpc, http/protobuf
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Additional resource attributes (comma-separated key=value pairs)
# OTEL_RESOURCE_ATTRIBUTES=env=development,team=research,version=1.0

# Enable requests auto-instrumentation for standardized HTTP client spans (default: true)
OTEL_INSTRUMENT_REQUESTS=true

# Use insecure connection for OTLP (default: true)
# Set to false if using TLS-enabled collector
OTEL_EXPORTER_OTLP_INSECURE=true

# ============================================================
# DEBUG CONFIGURATION (Optional)
# ============================================================

# Log level (default: INFO)
# Set to DEBUG to enable verbose logging with detailed debug information
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# Log prompt details (default: 0)
#LOG_PROMPT=0

# Log response details (default: 0)
#LOG_RESPONSE=0
